VIDEW_FOOTER_USEFUL_LINK_1_URL="index.php#catalog"
VIDEW_FOOTER_USEFUL_LINK_2_LABEL="Account"
VIDEW_FOOTER_USEFUL_LINK_2_URL="account.php"
VIDEW_FOOTER_USEFUL_LINK_3_LABEL="Sign in"
VIDEW_FOOTER_USEFUL_LINK_3_URL="login.php"
VIDEW_FOOTER_LEGAL_LINK_1_LABEL="Platform rules"
VIDEW_FOOTER_LEGAL_LINK_1_URL="rules.php"
VIDEW_FOOTER_LEGAL_LINK_2_LABEL="Terms of use"
VIDEW_FOOTER_LEGAL_LINK_2_URL="terms.php"
VIDEW_FOOTER_LEGAL_LINK_3_LABEL="Privacy policy"
