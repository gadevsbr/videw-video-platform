VIDEW_FOOTER_LEGAL_LINK_4_LABEL="Cookie policy"
VIDEW_FOOTER_LEGAL_LINK_4_URL="cookies.php"

# Legal pages
VIDEW_RULES_NAV_LABEL="Rules"
VIDEW_RULES_KICKER="Rules"
VIDEW_RULES_PAGE_TITLE="Built for a clear 18+ platform"
VIDEW_RULES_PAGE_INTRO="This page explains how the platform handles age checks, consent, access levels, and review."
VIDEW_RULES_CARD_1_TITLE="Age check"
VIDEW_RULES_CARD_1_TEXT="Entry is limited to adults 18+ with a clear age gate."
VIDEW_RULES_CARD_2_TITLE="Consent"
VIDEW_RULES_CARD_2_TEXT="Creators and records should be tied to every upload."
VIDEW_RULES_CARD_3_TITLE="Access"
VIDEW_RULES_CARD_3_TEXT="Free and premium content stay clearly separated."
VIDEW_RULES_CARD_4_TITLE="Review"
VIDEW_RULES_CARD_4_TEXT="Uploads can be checked before they go live."
VIDEW_TERMS_KICKER="Terms"
VIDEW_TERMS_TITLE="Terms of Use"
VIDEW_TERMS_INTRO="Read these terms before using the site."
VIDEW_TERMS_CONTENT="You must be 18 or older to access this site.\n\nYou are responsible for using the platform in compliance with your local laws.\n\nWe may suspend accounts, remove uploads, or limit access when these terms are broken."
VIDEW_PRIVACY_KICKER="Privacy"
VIDEW_PRIVACY_TITLE="Privacy Policy"
VIDEW_PRIVACY_INTRO="This policy explains what information is collected and why."
VIDEW_PRIVACY_CONTENT="We collect the minimum data needed to run accounts, secure sessions, and operate the site.\n\nWe may process account details, IP logs, moderation records, and support communications.\n\nYou can contact support for privacy-related requests using the email listed in the footer."
VIDEW_COOKIES_KICKER="Cookies"
VIDEW_COOKIES_TITLE="Cookie Policy"
VIDEW_COOKIES_INTRO="This page explains how cookies and similar storage are used on the site."
VIDEW_COOKIES_CONTENT="We use cookies or similar storage to keep your session active, remember preferences, and improve performance.\n\nSome cookies are necessary for login, age-gate state, and security features such as multi-factor authentication.\n\nYou can review this page at any time from the footer links."

# Cookie notice
VIDEW_COOKIE_NOTICE_ENABLED="1"
VIDEW_COOKIE_NOTICE_TITLE="Cookie notice"
VIDEW_COOKIE_NOTICE_TEXT="This site uses cookies or similar storage to keep sessions active, remember preferences, and improve performance."
VIDEW_COOKIE_NOTICE_ACCEPT_LABEL="Accept"
VIDEW_COOKIE_NOTICE_LINK_LABEL="Read cookie policy"
VIDEW_COOKIE_NOTICE_LINK_URL="cookies.php"

# Session
VIDEW_SESSION_NAME="videw_session"
VIDEW_SESSION_COOKIE_LIFETIME="0"
VIDEW_SESSION_SECURE_COOKIE="0"
VIDEW_SESSION_HTTP_ONLY="1"
VIDEW_SESSION_SAME_SITE="Lax"

# Database
VIDEW_DB_HOST="127.0.0.1"
VIDEW_DB_PORT="3306"
VIDEW_DB_DATABASE="videw"
VIDEW_DB_USERNAME="root"
VIDEW_DB_PASSWORD=""
VIDEW_DB_CHARSET="utf8mb4"

# Local storage
VIDEW_LOCAL_STORAGE_ROOT="storage/uploads"
VIDEW_LOCAL_STORAGE_BASE_URL="https://your-domain.example/storage/uploads"
VIDEW_STORAGE_DRIVER="local"

