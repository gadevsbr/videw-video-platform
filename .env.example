# App
VIDEW_APP_NAME="VIDEW 18+"
VIDEW_APP_DESCRIPTION="Adult-only video platform with verified creators, age gate, and private catalog access."
VIDEW_BRAND_KICKER="VIDEW"
VIDEW_BRAND_TITLE="18+"
VIDEW_BASE_URL="https://your-domain.example"
VIDEW_SUPPORT_EMAIL="support@example.com"
VIDEW_EXIT_URL="https://www.google.com"
VIDEW_TIMEZONE="America/Sao_Paulo"

# Footer
VIDEW_FOOTER_TAGLINE="Adult-only video platform with verified creators, age gate, and private catalog access."
VIDEW_FOOTER_USEFUL_TITLE="Useful links"
VIDEW_FOOTER_LEGAL_TITLE="Legal"
VIDEW_FOOTER_SUPPORT_TITLE="Support"
VIDEW_FOOTER_SUPPORT_COPY="Questions, takedowns, and legal notices."
